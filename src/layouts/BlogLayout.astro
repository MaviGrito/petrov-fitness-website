---
import Layout from './Layout.astro';

interface PostFrontmatter {
  featured_image?: string;
  date: Date;
  category: string;
  author?: string;
  [key: string]: unknown;
}

interface Props {
  title: string;
  description: string;
  post: PostFrontmatter;
  image?: string;
}

const { title, description, post, image } = Astro.props;

// Estimate read time (avg 200 words/min)
const wordsPerMinute = 200;

// Format date
const formattedDate = new Date(post.date).toLocaleDateString('en-AU', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const author = post.author || 'Mikhail Petrov';
const featuredImage = post.featured_image || image;
---

<Layout title={title} description={description} image={featuredImage}>
  <article>
    <!-- Featured image -->
    {featuredImage && (
      <div class="w-full max-h-[500px] overflow-hidden bg-brand-black">
        <img
          src={featuredImage}
          alt={title}
          loading="lazy"
          class="w-full h-full object-cover max-h-[500px]"
          width="1200"
          height="500"
        />
      </div>
    )}

    <!-- Post metadata bar -->
    <div class="bg-brand-black border-b border-white/10">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-5">
        <!-- Breadcrumb -->
        <nav aria-label="Breadcrumb" class="mb-4">
          <ol class="flex items-center gap-2 text-sm font-body text-white/50">
            <li><a href="/" class="hover:text-brand-yellow transition-colors duration-200">Home</a></li>
            <li aria-hidden="true" class="text-white/30">/</li>
            <li><a href="/blog" class="hover:text-brand-yellow transition-colors duration-200">Blog</a></li>
            <li aria-hidden="true" class="text-white/30">/</li>
            <li class="text-brand-yellow font-medium truncate max-w-[200px]" aria-current="page">{title}</li>
          </ol>
        </nav>

        <div class="flex flex-wrap items-center gap-4 text-sm font-body text-white/60">
          <!-- Category badge -->
          <span class="bg-brand-yellow text-brand-black font-bold text-xs uppercase tracking-wide px-3 py-1 rounded-full">
            {post.category}
          </span>

          <!-- Date -->
          <time datetime={new Date(post.date).toISOString()} class="flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-brand-yellow" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            {formattedDate}
          </time>

          <!-- Author -->
          <span class="flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-brand-yellow" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
            {author}
          </span>

          <!-- Estimated read time -->
          <span class="flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-brand-yellow" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            5 min read
          </span>
        </div>
      </div>
    </div>

    <!-- Post content -->
    <div class="bg-white">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="prose prose-lg prose-gray max-w-none
          prose-headings:font-heading prose-headings:font-bold prose-headings:text-brand-black
          prose-a:text-brand-blue prose-a:no-underline hover:prose-a:underline
          prose-strong:text-brand-black
          prose-img:rounded-lg prose-img:shadow-md">
          <slot />
        </div>
      </div>
    </div>
  </article>
</Layout>
