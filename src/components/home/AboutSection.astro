---
import CalComPopup from '../shared/CalComPopup.astro';

const certifications = [
  'Cert IV Fitness Trainer',
  'AUSActive Registered',
  'First Aid & CPR Certified',
  'WWCC Certified',
  'Level 1 S&C Accredited',
  '2019 Boxing State Champion (Silver)',
];
---

<section class="bg-white py-20 md:py-28">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <!-- Left: Profile photo -->
      <div class="flex justify-center lg:justify-start">
        <img
          src="/images/mikhail-profile.png"
          alt="Mikhail Petrov - Personal Trainer Adelaide"
          loading="lazy"
          width="500"
          height="600"
          class="w-full max-w-sm lg:max-w-none rounded-2xl object-cover object-top shadow-xl"
          style="max-height: 600px;"
        />
      </div>

      <!-- Right: Bio content -->
      <div>
        <!-- Eyebrow tag -->
        <span class="font-heading font-bold text-xs uppercase tracking-widest text-brand-blue mb-3 block">
          Meet Your Coach
        </span>

        <!-- Name -->
        <h2 class="font-heading font-black text-4xl md:text-5xl uppercase tracking-tight text-brand-black mb-2">
          Mikhail Petrov
        </h2>

        <!-- Subheadline -->
        <p class="font-body text-lg text-brand-blue font-semibold mb-6">
          Adelaide's Hypertrophy &amp; Boxing Specialist
        </p>

        <!-- Bio -->
        <div class="font-body text-gray-700 space-y-4 mb-8 text-base leading-relaxed">
          <p>
            With over 5 years of professional personal training experience in Adelaide, I specialise in helping clients achieve real, lasting transformations through science-backed hypertrophy training, body recomposition, and boxing fitness.
          </p>
          <p>
            My journey in fitness began as a competitive boxer — earning a Silver Medal at the 2019 South Australian State Championships — and evolved into a passion for helping others unlock their physical potential. I hold a Certificate IV in Fitness, am AUSActive Registered, and continuously update my knowledge to deliver the most effective training methods.
          </p>
          <p>
            Whether you're a complete beginner or an experienced athlete, I tailor every program to your unique goals, lifestyle, and body. I train clients at Goodlife Health Clubs Payneham and offer online coaching across Australia.
          </p>
        </div>

        <!-- Certifications -->
        <div class="mb-8">
          <p class="font-heading font-bold text-xs uppercase tracking-widest text-gray-500 mb-3">Certifications &amp; Credentials</p>
          <div class="flex flex-wrap gap-2">
            {certifications.map(cert => (
              <span class="bg-brand-yellow text-brand-black font-heading font-bold text-xs uppercase tracking-wide px-3 py-1.5 rounded-full">
                {cert}
              </span>
            ))}
          </div>
        </div>

        <!-- CTA -->
        <CalComPopup
          calLink="mikhail-petrov/free-consultation"
          label="Book a Free Consultation"
          variant="primary"
        />
      </div>
    </div>
  </div>
</section>
