---
import { services } from '../../data/services.ts';
import CalComPopup from '../shared/CalComPopup.astro';

// SVG icons map by service icon name
const icons: Record<string, string> = {
  dumbbell: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 8h2M4 8v8M4 8H2m2 8h2m-2 0H2m2 0v-8M20 8h-2M20 8v8M20 8h2m-2 8h-2m2 0h2m-2 0v-8M8 12h8" /></svg>`,
  laptop: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>`,
  'boxing-glove': `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" /></svg>`,
  chart: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>`,
  group: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" /></svg>`,
};
---

<section class="bg-brand-black py-20 md:py-28">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="text-center mb-14">
      <span class="font-heading font-bold text-xs uppercase tracking-widest text-brand-yellow mb-3 block">
        What I Offer
      </span>
      <h2 class="font-heading font-black text-4xl md:text-5xl uppercase tracking-tight text-white">
        Training Services
      </h2>
      <p class="mt-4 font-body text-lg text-white/60 max-w-2xl mx-auto">
        Tailored programs designed to help you reach your goals — whether in-person or online.
      </p>
    </div>

    <!-- Services grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {services.map(service => (
        <div class="group bg-[#111] border border-white/10 rounded-2xl p-6 flex flex-col hover:border-brand-yellow transition-colors duration-300">
          <!-- Icon -->
          <div class="text-brand-yellow mb-4" set:html={icons[service.icon] ?? icons['dumbbell']} />

          <!-- Name -->
          <h3 class="font-heading font-bold text-lg uppercase tracking-wide text-white mb-2">
            {service.name}
          </h3>

          <!-- Short description -->
          <p class="font-body text-sm text-white/60 leading-relaxed mb-6 flex-1">
            {service.description.slice(0, 100)}{service.description.length > 100 ? '…' : ''}
          </p>

          <!-- Meta -->
          <div class="flex items-center gap-4 text-xs text-white/40 font-body mb-6">
            <span>{service.duration}</span>
            <span class="w-1 h-1 rounded-full bg-white/30"></span>
            <span>{service.modality.split(' ')[0]}</span>
          </div>

          <!-- CTA -->
          <CalComPopup
            calLink={`mikhail-petrov/${service.calEventType}`}
            label="Book Now"
            variant="primary"
            class="w-full text-sm"
          />
        </div>
      ))}
    </div>

    <!-- View all services link -->
    <div class="text-center mt-10">
      <a
        href="/services"
        class="inline-flex items-center gap-2 font-heading font-bold text-sm uppercase tracking-wide text-brand-yellow hover:text-yellow-300 transition-colors duration-200"
      >
        View All Services
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>
</section>
