---
import CalComPopup from '../shared/CalComPopup.astro';
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-brand-black">
  <!-- Background gradient -->
  <div class="absolute inset-0 bg-gradient-to-br from-brand-black via-brand-black to-brand-blue opacity-90"></div>
  <!-- Subtle texture overlay -->
  <div class="absolute inset-0 opacity-5" style="background-image: repeating-linear-gradient(45deg, #fff 0, #fff 1px, transparent 0, transparent 50%); background-size: 20px 20px;"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 text-center">
    <!-- Tagline badge -->
    <div class="inline-flex items-center gap-2 bg-brand-yellow/10 border border-brand-yellow/30 text-brand-yellow font-heading font-bold text-xs uppercase tracking-widest px-4 py-2 rounded-full mb-8">
      <span>5+ Years Experience</span>
      <span class="w-1 h-1 rounded-full bg-brand-yellow"></span>
      <span>Hypertrophy Specialist</span>
      <span class="w-1 h-1 rounded-full bg-brand-yellow"></span>
      <span>Boxing Coach</span>
    </div>

    <!-- Main headline -->
    <h1 class="font-heading font-black text-4xl sm:text-5xl md:text-6xl lg:text-7xl xl:text-8xl uppercase tracking-tight text-white leading-none mb-6">
      Transform Your Body,<br />
      <span class="text-brand-yellow">Transform Your Life</span>
    </h1>

    <!-- Subheadline -->
    <p class="font-body text-lg sm:text-xl md:text-2xl text-white/80 max-w-2xl mx-auto mb-10">
      Professional Personal Training in Adelaide with Mikhail Petrov
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <!-- Primary CTA -->
      <div class="relative">
        <span class="absolute -top-3 -right-3 bg-red-500 text-white font-heading font-bold text-xs uppercase px-2 py-0.5 rounded-full z-10">
          50% OFF
        </span>
        <CalComPopup
          calLink="mikhail-petrov/first-pt-session"
          label="Book First Session (50% OFF)"
          variant="primary"
          class="text-base px-8 py-4"
        />
      </div>

      <!-- Secondary CTA -->
      <CalComPopup
        calLink="mikhail-petrov/free-consultation"
        label="Free Consultation"
        variant="secondary"
        class="text-base px-8 py-4"
      />
    </div>

    <!-- Scroll indicator -->
    <div class="mt-16 flex flex-col items-center gap-2 text-white/40 animate-bounce">
      <span class="font-body text-xs uppercase tracking-widest">Scroll Down</span>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
      </svg>
    </div>
  </div>
</section>
