---
const specialties = [
  {
    title: 'Hypertrophy Training',
    description: 'Science-backed muscle building programs using progressive overload, optimal volume, and periodisation to maximise muscle growth.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 8h2M4 8v8M4 8H2m2 8h2m-2 0H2m2 0v-8M20 8h-2M20 8v8M20 8h2m-2 8h-2m2 0h2m-2 0v-8M8 12h8" /></svg>`,
  },
  {
    title: 'Fat Loss & Body Recomposition',
    description: 'Sustainable fat loss strategies combined with muscle preservation to reshape your body composition without crash dieting.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.879 16.121A3 3 0 1012.015 11L11 14H9c0 .768.293 1.536.879 2.121z" /></svg>`,
  },
  {
    title: 'Boxing Fitness',
    description: 'High-intensity boxing workouts that build strength, endurance, and mental toughness. No prior experience needed — all levels welcome.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" /></svg>`,
  },
  {
    title: 'Strength Training',
    description: 'Build functional strength through compound movements, powerlifting techniques, and progressive programming tailored to your level.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>`,
  },
  {
    title: 'Youth Fitness',
    description: 'Safe, age-appropriate training programs for young athletes and teens to build healthy habits, confidence, and athletic foundations.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" /></svg>`,
  },
];
---

<section class="bg-brand-blue py-20 md:py-28">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="text-center mb-14">
      <span class="font-heading font-bold text-xs uppercase tracking-widest text-brand-yellow mb-3 block">
        Areas of Expertise
      </span>
      <h2 class="font-heading font-black text-4xl md:text-5xl uppercase tracking-tight text-white">
        My Specialties
      </h2>
      <p class="mt-4 font-body text-lg text-white/70 max-w-2xl mx-auto">
        Focused expertise across five key areas of fitness to help you achieve your specific goals.
      </p>
    </div>

    <!-- Specialties grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {specialties.map((specialty, index) => (
        <div class={`bg-white/10 border border-white/20 rounded-2xl p-8 hover:bg-white/15 transition-colors duration-300 ${index === 4 ? 'sm:col-span-2 lg:col-span-1' : ''}`}>
          <!-- Icon -->
          <div class="text-brand-yellow mb-5" set:html={specialty.icon} />

          <!-- Title -->
          <h3 class="font-heading font-bold text-xl uppercase tracking-wide text-white mb-3">
            {specialty.title}
          </h3>

          <!-- Description -->
          <p class="font-body text-sm text-white/70 leading-relaxed">
            {specialty.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
