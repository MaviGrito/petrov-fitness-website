---
const contactInfo = {
  phone: '+61 415 522 832',
  phoneHref: 'tel:+61415522832',
  email: 'petrovcoachfitness@gmail.com',
  emailHref: 'mailto:petrovcoachfitness@gmail.com',
  address: '7 Portrush Rd, Payneham SA 5070',
  addressLink: 'https://maps.app.goo.gl/3qtWFmGKsGg4A65w6',
  instagram: 'https://www.instagram.com/mikhail_saustralia',
  facebook: 'https://www.facebook.com/share/189Sg6fTzj/',
};

const mapsEmbedUrl = 'https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3271.5!2d138.637!3d-34.909!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2sGoodlife+Health+Clubs+Payneham!5e0!3m2!1sen!2sau!4v1';
---

<section class="bg-white py-20 md:py-28">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="text-center mb-14">
      <span class="font-heading font-bold text-xs uppercase tracking-widest text-brand-blue mb-3 block">
        Find Me
      </span>
      <h2 class="font-heading font-black text-4xl md:text-5xl uppercase tracking-tight text-brand-black">
        Location &amp; Contact
      </h2>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-start">
      <!-- Left: Google Maps -->
      <div class="rounded-2xl overflow-hidden shadow-lg border border-gray-200 aspect-video lg:aspect-auto lg:h-96">
        <iframe
          src={mapsEmbedUrl}
          width="100%"
          height="100%"
          style="border:0; min-height: 384px;"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Goodlife Health Clubs Payneham - Petrov Fitness location"
          class="w-full h-full"
        ></iframe>
      </div>

      <!-- Right: Contact info -->
      <div class="space-y-8">
        <div>
          <h3 class="font-heading font-bold text-xl uppercase tracking-wide text-brand-black mb-4">
            Petrov Fitness
          </h3>
          <p class="font-body text-gray-600 text-sm leading-relaxed">
            Based at Goodlife Health Clubs Payneham, Adelaide SA. Also offering Online Coaching across Australia.
          </p>
        </div>

        <!-- Contact details -->
        <ul class="space-y-4">
          <!-- Phone -->
          <li class="flex items-start gap-4">
            <div class="flex-shrink-0 w-10 h-10 bg-brand-yellow rounded-full flex items-center justify-center">
              <svg class="w-5 h-5 text-brand-black" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div>
              <p class="font-heading font-bold text-xs uppercase tracking-widest text-gray-400 mb-0.5">Phone</p>
              <a href={contactInfo.phoneHref} class="font-body text-brand-black hover:text-brand-blue transition-colors duration-200">
                {contactInfo.phone}
              </a>
            </div>
          </li>

          <!-- Email -->
          <li class="flex items-start gap-4">
            <div class="flex-shrink-0 w-10 h-10 bg-brand-yellow rounded-full flex items-center justify-center">
              <svg class="w-5 h-5 text-brand-black" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <p class="font-heading font-bold text-xs uppercase tracking-widest text-gray-400 mb-0.5">Email</p>
              <a href={contactInfo.emailHref} class="font-body text-brand-black hover:text-brand-blue transition-colors duration-200 break-all">
                {contactInfo.email}
              </a>
            </div>
          </li>

          <!-- Address -->
          <li class="flex items-start gap-4">
            <div class="flex-shrink-0 w-10 h-10 bg-brand-yellow rounded-full flex items-center justify-center">
              <svg class="w-5 h-5 text-brand-black" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <p class="font-heading font-bold text-xs uppercase tracking-widest text-gray-400 mb-0.5">Address</p>
              <a
                href={contactInfo.addressLink}
                target="_blank"
                rel="noopener noreferrer"
                class="font-body text-brand-black hover:text-brand-blue transition-colors duration-200"
              >
                {contactInfo.address}
              </a>
              <p class="font-body text-xs text-gray-400 mt-1">Goodlife Health Clubs Payneham</p>
            </div>
          </li>

          <!-- Online coaching note -->
          <li class="flex items-start gap-4">
            <div class="flex-shrink-0 w-10 h-10 bg-brand-blue rounded-full flex items-center justify-center">
              <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <p class="font-heading font-bold text-xs uppercase tracking-widest text-gray-400 mb-0.5">Online Coaching</p>
              <p class="font-body text-brand-black">Also offering Online Coaching across Australia</p>
            </div>
          </li>
        </ul>

        <!-- Social links -->
        <div>
          <p class="font-heading font-bold text-xs uppercase tracking-widest text-gray-400 mb-3">Follow Along</p>
          <div class="flex gap-3">
            <a
              href={contactInfo.instagram}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 bg-brand-black text-white font-heading font-bold text-xs uppercase tracking-wide px-4 py-2.5 rounded hover:bg-brand-blue transition-colors duration-200"
              aria-label="Follow on Instagram"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
              </svg>
              Instagram
            </a>
            <a
              href={contactInfo.facebook}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 bg-brand-black text-white font-heading font-bold text-xs uppercase tracking-wide px-4 py-2.5 rounded hover:bg-brand-blue transition-colors duration-200"
              aria-label="Follow on Facebook"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
              Facebook
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
