---
import { testimonials } from '../../data/testimonials.ts';
---

<section class="bg-brand-black py-20 md:py-28">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="text-center mb-14">
      <span class="font-heading font-bold text-xs uppercase tracking-widest text-brand-yellow mb-3 block">
        Client Results
      </span>
      <h2 class="font-heading font-black text-4xl md:text-5xl uppercase tracking-tight text-white">
        What Clients Say
      </h2>
      <p class="mt-4 font-body text-lg text-white/60 max-w-2xl mx-auto">
        Real results from real people. Here's what my clients have to say about training with me.
      </p>
    </div>

    <!-- Testimonials grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {testimonials.map(testimonial => (
        <div class="bg-[#111] border border-white/10 rounded-2xl p-6 flex flex-col hover:border-brand-yellow/30 transition-colors duration-300">
          <!-- Stars -->
          <div class="flex gap-1 mb-4" aria-label={`${testimonial.rating} out of 5 stars`}>
            {Array.from({ length: 5 }).map((_, i) => (
              <svg
                class={`w-5 h-5 ${i < testimonial.rating ? 'text-brand-yellow' : 'text-white/20'}`}
                fill="currentColor"
                viewBox="0 0 20 20"
                aria-hidden="true"
              >
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>

          <!-- Quote -->
          <blockquote class="font-body text-sm text-white/80 leading-relaxed flex-1 mb-6 italic">
            "{testimonial.text}"
          </blockquote>

          <!-- Client info -->
          <div class="border-t border-white/10 pt-4">
            <p class="font-heading font-bold text-sm uppercase tracking-wide text-white">
              {testimonial.name}
            </p>
            <p class="font-body text-xs text-brand-yellow mt-0.5">
              {testimonial.service}
            </p>
            {testimonial.duration && (
              <p class="font-body text-xs text-white/40 mt-0.5">
                {testimonial.duration}
              </p>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
