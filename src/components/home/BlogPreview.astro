---
interface BlogPost {
  slug: string;
  data: {
    title: string;
    date: Date;
    category: string;
    excerpt: string;
    featured_image: string;
  };
}

interface Props {
  posts: BlogPost[];
}

const { posts } = Astro.props;
const displayPosts = posts.slice(0, 3);

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-AU', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<section class="bg-white py-20 md:py-28">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="text-center mb-14">
      <span class="font-heading font-bold text-xs uppercase tracking-widest text-brand-blue mb-3 block">
        Knowledge Hub
      </span>
      <h2 class="font-heading font-black text-4xl md:text-5xl uppercase tracking-tight text-brand-black">
        Latest Articles
      </h2>
      <p class="mt-4 font-body text-lg text-gray-600 max-w-2xl mx-auto">
        Tips, insights, and expert advice on training, nutrition, and achieving your fitness goals.
      </p>
    </div>

    {displayPosts.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {displayPosts.map(post => (
          <article class="group bg-white border border-gray-200 rounded-2xl overflow-hidden hover:shadow-lg transition-shadow duration-300">
            <!-- Featured image -->
            <a href={`/blog/${post.slug}`} class="block overflow-hidden aspect-video bg-gray-100" aria-label={`Read ${post.data.title}`}>
              {post.data.featured_image ? (
                <img
                  src={post.data.featured_image}
                  alt={post.data.title}
                  loading="lazy"
                  width="600"
                  height="338"
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                />
              ) : (
                <div class="w-full h-full bg-gradient-to-br from-brand-blue to-brand-black flex items-center justify-center">
                  <svg class="w-12 h-12 text-white/30" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                </div>
              )}
            </a>

            <!-- Content -->
            <div class="p-6">
              <!-- Category badge -->
              <span class="inline-block bg-brand-yellow text-brand-black font-heading font-bold text-xs uppercase tracking-wide px-3 py-1 rounded-full mb-3">
                {post.data.category}
              </span>

              <!-- Title -->
              <h3 class="font-heading font-bold text-lg uppercase tracking-tight text-brand-black mb-2 leading-snug">
                <a href={`/blog/${post.slug}`} class="hover:text-brand-blue transition-colors duration-200">
                  {post.data.title}
                </a>
              </h3>

              <!-- Date -->
              <time
                datetime={post.data.date.toISOString()}
                class="font-body text-xs text-gray-400 block mb-3"
              >
                {formatDate(post.data.date)}
              </time>

              <!-- Excerpt -->
              <p class="font-body text-sm text-gray-600 leading-relaxed mb-4 line-clamp-3">
                {post.data.excerpt}
              </p>

              <!-- Read more -->
              <a
                href={`/blog/${post.slug}`}
                class="inline-flex items-center gap-1.5 font-heading font-bold text-xs uppercase tracking-wide text-brand-blue hover:text-brand-black transition-colors duration-200"
              >
                Read More
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </a>
            </div>
          </article>
        ))}
      </div>
    ) : (
      <div class="text-center py-16 text-gray-400">
        <p class="font-body text-lg">No articles yet. Check back soon!</p>
      </div>
    )}

    <!-- View all CTA -->
    <div class="text-center mt-12">
      <a
        href="/blog"
        class="inline-flex items-center gap-2 bg-brand-black text-white font-heading font-bold text-sm uppercase tracking-wide px-8 py-4 rounded hover:bg-brand-blue transition-colors duration-200"
      >
        View All Articles
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>
</section>
