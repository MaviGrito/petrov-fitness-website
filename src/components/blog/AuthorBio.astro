---
import CalComPopup from '../shared/CalComPopup.astro';
---

<div class="author-bio flex flex-col sm:flex-row gap-6 items-start">
  <!-- Photo -->
  <div class="flex-shrink-0">
    <img
      src="/images/mikhail-profile.png"
      alt="Mikhail Petrov - Personal Trainer Adelaide"
      loading="lazy"
      width="80"
      height="80"
      class="w-20 h-20 rounded-full object-cover object-top"
    />
  </div>

  <!-- Bio content -->
  <div class="flex-1">
    <h3 class="font-heading font-black text-xl uppercase tracking-tight text-brand-black mb-0.5">
      Mikhail Petrov
    </h3>
    <p class="font-body text-sm text-brand-blue font-semibold mb-3">
      Personal Trainer | Adelaide, SA
    </p>
    <p class="font-body text-sm text-gray-600 leading-relaxed mb-4">
      Mikhail is a certified personal trainer based in Adelaide, South Australia, specialising in hypertrophy training, body recomposition, boxing fitness, and strength training. A 2019 SA State Boxing Championship Silver Medallist, he brings competitive experience and evidence-based methods to every client's journey.
    </p>

    <!-- Social links + CTA -->
    <div class="flex flex-wrap items-center gap-3">
      <!-- Instagram -->
      <a
        href="https://www.instagram.com/petrovcoachfitness"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 font-body text-sm text-gray-600 hover:text-brand-blue transition-colors duration-200 focus:outline-none focus:underline"
        aria-label="Mikhail Petrov on Instagram"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
        </svg>
        Instagram
      </a>

      <!-- Facebook -->
      <a
        href="https://www.facebook.com/petrovcoachfitness"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 font-body text-sm text-gray-600 hover:text-brand-blue transition-colors duration-200 focus:outline-none focus:underline"
        aria-label="Mikhail Petrov on Facebook"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
        </svg>
        Facebook
      </a>

      <!-- CTA -->
      <CalComPopup
        calLink="mikhail-petrov/first-pt-session"
        label="Train with Mikhail"
        variant="primary"
      />
    </div>
  </div>
</div>
