---
const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'Services', href: '/services' },
  { label: 'Blog', href: '/blog' },
  { label: 'Contact', href: '/contact' },
];
---

<header class="sticky top-0 z-50 bg-brand-black border-b border-white/10">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="text-brand-yellow font-heading font-bold text-xl uppercase tracking-widest hover:opacity-80 transition-opacity">
        PETROV FITNESS
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center gap-8">
        {navLinks.map(link => (
          <a
            href={link.href}
            class="text-white font-body text-sm font-medium uppercase tracking-wide hover:text-brand-yellow transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-brand-yellow rounded"
          >
            {link.label}
          </a>
        ))}
        <a
          href="#booking"
          class="bg-brand-yellow text-brand-black font-heading font-bold text-sm uppercase tracking-wide px-5 py-2 rounded hover:bg-yellow-400 transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-brand-yellow focus:ring-offset-2"
        >
          Book Now
        </a>
      </nav>

      <!-- Mobile hamburger -->
      <button
        id="menu-toggle"
        class="md:hidden flex flex-col justify-center items-center w-10 h-10 gap-1.5 focus:outline-none focus:ring-2 focus:ring-brand-yellow rounded"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span class="hamburger-line block w-6 h-0.5 bg-white transition-all duration-300"></span>
        <span class="hamburger-line block w-6 h-0.5 bg-white transition-all duration-300"></span>
        <span class="hamburger-line block w-6 h-0.5 bg-white transition-all duration-300"></span>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="md:hidden hidden bg-brand-black border-t border-white/10"
  >
    <nav class="flex flex-col px-4 py-4 gap-1">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="text-white font-body text-base font-medium uppercase tracking-wide py-3 border-b border-white/10 hover:text-brand-yellow transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-brand-yellow rounded"
        >
          {link.label}
        </a>
      ))}
      <a
        href="#booking"
        class="mt-3 bg-brand-yellow text-brand-black font-heading font-bold text-sm uppercase tracking-wide px-5 py-3 rounded text-center hover:bg-yellow-400 transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-brand-yellow focus:ring-offset-2"
      >
        Book Now
      </a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    toggle.setAttribute('aria-expanded', String(!isOpen));

    // Animate hamburger lines
    const lines = toggle.querySelectorAll('.hamburger-line');
    if (!isOpen) {
      lines[0]?.classList.add('rotate-45', 'translate-y-2');
      lines[1]?.classList.add('opacity-0');
      lines[2]?.classList.add('-rotate-45', '-translate-y-2');
    } else {
      lines[0]?.classList.remove('rotate-45', 'translate-y-2');
      lines[1]?.classList.remove('opacity-0');
      lines[2]?.classList.remove('-rotate-45', '-translate-y-2');
    }
  });
</script>
