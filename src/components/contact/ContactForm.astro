---
// ContactForm.astro — Netlify Forms integration with client-side validation
---

<div id="contact-form-wrapper">
  <!-- Success message (hidden by default) -->
  <div
    id="form-success"
    class="hidden bg-green-50 border border-green-200 rounded-xl p-6 text-center"
    role="alert"
    aria-live="polite"
  >
    <div class="flex justify-center mb-3">
      <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center">
        <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
        </svg>
      </div>
    </div>
    <h3 class="font-heading font-bold text-xl text-green-800 mb-2">Message Sent!</h3>
    <p class="font-body text-green-700">
      Thanks for reaching out. Mikhail will get back to you within 24 hours.
    </p>
  </div>

  <!-- Contact form -->
  <form
    id="contact-form"
    name="contact"
    method="POST"
    data-netlify="true"
    netlify-honeypot="bot-field"
    novalidate
    class="space-y-6"
  >
    <input type="hidden" name="form-name" value="contact" />

    <!-- Honeypot (hidden from real users) -->
    <div class="hidden" aria-hidden="true">
      <label>
        Don't fill this out if you're human:
        <input name="bot-field" tabindex="-1" autocomplete="off" />
      </label>
    </div>

    <!-- Name -->
    <div>
      <label for="contact-name" class="block font-heading font-bold text-sm uppercase tracking-widest text-brand-blue mb-2">
        Full Name <span class="text-red-500" aria-hidden="true">*</span>
      </label>
      <input
        type="text"
        id="contact-name"
        name="name"
        required
        autocomplete="name"
        placeholder="e.g. John Smith"
        class="w-full bg-white border border-gray-200 rounded-lg px-4 py-3 font-body text-brand-black placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-yellow focus:border-transparent transition-all duration-200"
        aria-describedby="name-error"
        aria-required="true"
      />
      <p id="name-error" class="hidden mt-1.5 text-sm font-body text-red-600" role="alert"></p>
    </div>

    <!-- Email -->
    <div>
      <label for="contact-email" class="block font-heading font-bold text-sm uppercase tracking-widest text-brand-blue mb-2">
        Email Address <span class="text-red-500" aria-hidden="true">*</span>
      </label>
      <input
        type="email"
        id="contact-email"
        name="email"
        required
        autocomplete="email"
        placeholder="e.g. john@example.com"
        class="w-full bg-white border border-gray-200 rounded-lg px-4 py-3 font-body text-brand-black placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-yellow focus:border-transparent transition-all duration-200"
        aria-describedby="email-error"
        aria-required="true"
      />
      <p id="email-error" class="hidden mt-1.5 text-sm font-body text-red-600" role="alert"></p>
    </div>

    <!-- Phone (optional) -->
    <div>
      <label for="contact-phone" class="block font-heading font-bold text-sm uppercase tracking-widest text-brand-blue mb-2">
        Phone Number <span class="font-body font-normal text-xs text-gray-400 normal-case tracking-normal">(optional)</span>
      </label>
      <input
        type="tel"
        id="contact-phone"
        name="phone"
        autocomplete="tel"
        placeholder="e.g. 0415 522 832"
        class="w-full bg-white border border-gray-200 rounded-lg px-4 py-3 font-body text-brand-black placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-yellow focus:border-transparent transition-all duration-200"
      />
    </div>

    <!-- Service of interest -->
    <div>
      <label for="contact-service" class="block font-heading font-bold text-sm uppercase tracking-widest text-brand-blue mb-2">
        Service of Interest
      </label>
      <div class="relative">
        <select
          id="contact-service"
          name="service"
          class="w-full appearance-none bg-white border border-gray-200 rounded-lg px-4 py-3 font-body text-brand-black focus:outline-none focus:ring-2 focus:ring-brand-yellow focus:border-transparent transition-all duration-200 cursor-pointer"
        >
          <option value="">— Select a service —</option>
          <option value="General Enquiry">General Enquiry</option>
          <option value="Personal Training (1-on-1)">Personal Training (1-on-1)</option>
          <option value="Online Coaching">Online Coaching</option>
          <option value="Boxing Fitness Classes">Boxing Fitness Classes</option>
          <option value="Body Composition Assessment">Body Composition Assessment</option>
          <option value="Group Training">Group Training</option>
        </select>
        <!-- Custom chevron -->
        <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-4 text-gray-500">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </div>
      </div>
    </div>

    <!-- Message -->
    <div>
      <label for="contact-message" class="block font-heading font-bold text-sm uppercase tracking-widest text-brand-blue mb-2">
        Message <span class="text-red-500" aria-hidden="true">*</span>
      </label>
      <textarea
        id="contact-message"
        name="message"
        required
        rows="5"
        placeholder="Tell Mikhail about your fitness goals, current experience level, or any questions you have..."
        class="w-full bg-white border border-gray-200 rounded-lg px-4 py-3 font-body text-brand-black placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-yellow focus:border-transparent transition-all duration-200 resize-y"
        aria-describedby="message-error"
        aria-required="true"
      ></textarea>
      <p id="message-error" class="hidden mt-1.5 text-sm font-body text-red-600" role="alert"></p>
    </div>

    <!-- Submit -->
    <button
      type="submit"
      id="submit-btn"
      class="w-full bg-brand-yellow text-brand-black font-heading font-bold text-sm uppercase tracking-widest px-8 py-4 rounded-lg hover:bg-yellow-400 focus:outline-none focus:ring-2 focus:ring-brand-yellow focus:ring-offset-2 transition-all duration-200 flex items-center justify-center gap-2 disabled:opacity-60 disabled:cursor-not-allowed"
    >
      <span id="submit-label">Send Message</span>
      <svg id="submit-spinner" class="hidden w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24" aria-hidden="true">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
      </svg>
    </button>

    <p class="text-center font-body text-xs text-gray-400">
      <span aria-hidden="true">*</span> Required fields. Your information is kept private and never shared.
    </p>
  </form>
</div>

<script>
  import { validateContactForm } from '../../utils/validation.ts';

  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const successMsg = document.getElementById('form-success');
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;
  const submitLabel = document.getElementById('submit-label');
  const submitSpinner = document.getElementById('submit-spinner');

  // Field refs
  const nameInput = document.getElementById('contact-name') as HTMLInputElement | null;
  const emailInput = document.getElementById('contact-email') as HTMLInputElement | null;
  const messageInput = document.getElementById('contact-message') as HTMLTextAreaElement | null;

  // Error paragraph refs
  const nameError = document.getElementById('name-error');
  const emailError = document.getElementById('email-error');
  const messageError = document.getElementById('message-error');

  function showError(el: HTMLElement | null, input: HTMLElement | null, msg: string) {
    if (!el || !input) return;
    el.textContent = msg;
    el.classList.remove('hidden');
    input.classList.add('border-red-400', 'focus:ring-red-400');
    input.classList.remove('border-gray-200');
    input.setAttribute('aria-invalid', 'true');
  }

  function clearError(el: HTMLElement | null, input: HTMLElement | null) {
    if (!el || !input) return;
    el.textContent = '';
    el.classList.add('hidden');
    input.classList.remove('border-red-400', 'focus:ring-red-400');
    input.classList.add('border-gray-200');
    input.removeAttribute('aria-invalid');
  }

  function clearAllErrors() {
    clearError(nameError, nameInput);
    clearError(emailError, emailInput);
    clearError(messageError, messageInput);
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    clearAllErrors();

    const formData = {
      name: nameInput?.value ?? '',
      email: emailInput?.value ?? '',
      phone: (document.getElementById('contact-phone') as HTMLInputElement | null)?.value,
      service: (document.getElementById('contact-service') as HTMLSelectElement | null)?.value,
      message: messageInput?.value ?? '',
    };

    const errors = validateContactForm(formData);

    if (Object.keys(errors).length > 0) {
      if (errors.name) showError(nameError, nameInput, errors.name);
      if (errors.email) showError(emailError, emailInput, errors.email);
      if (errors.message) showError(messageError, messageInput, errors.message);

      // Focus first error field
      if (errors.name) nameInput?.focus();
      else if (errors.email) emailInput?.focus();
      else if (errors.message) messageInput?.focus();
      return;
    }

    // Submit to Netlify
    if (submitBtn) submitBtn.disabled = true;
    submitLabel?.classList.add('hidden');
    submitSpinner?.classList.remove('hidden');

    try {
      const body = new URLSearchParams();
      body.append('form-name', 'contact');
      body.append('name', formData.name);
      body.append('email', formData.email);
      if (formData.phone) body.append('phone', formData.phone);
      if (formData.service) body.append('service', formData.service);
      body.append('message', formData.message);

      const response = await fetch('/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: body.toString(),
      });

      if (response.ok) {
        form.classList.add('hidden');
        successMsg?.classList.remove('hidden');
      } else {
        throw new Error('Network response was not ok');
      }
    } catch {
      // Re-enable form on error
      if (submitBtn) submitBtn.disabled = false;
      submitLabel?.classList.remove('hidden');
      submitSpinner?.classList.add('hidden');
      // Show a generic error at the top of the form
      const genericError = document.createElement('p');
      genericError.className = 'text-sm font-body text-red-600 text-center';
      genericError.textContent = 'Something went wrong. Please try again or email us directly.';
      genericError.setAttribute('role', 'alert');
      form.prepend(genericError);
      setTimeout(() => genericError.remove(), 6000);
    }
  });

  // Clear errors on input
  nameInput?.addEventListener('input', () => clearError(nameError, nameInput));
  emailInput?.addEventListener('input', () => clearError(emailError, emailInput));
  messageInput?.addEventListener('input', () => clearError(messageError, messageInput));
</script>
