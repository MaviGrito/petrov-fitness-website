---
const faqs = [
  {
    question: "Do I need prior experience to start training with you?",
    answer: "Not at all! I work with clients of all fitness levels — from complete beginners to experienced athletes. Every program is tailored to your current fitness level, goals, and any limitations you may have. We start where you are and build from there.",
  },
  {
    question: "How long are training sessions?",
    answer: "Standard personal training sessions are 60 minutes. Boxing classes typically run 45–60 minutes. Body Composition Assessments are approximately 30 minutes. Online coaching is flexible and self-paced.",
  },
  {
    question: "What should I bring to my first session?",
    answer: "Wear comfortable workout clothes and athletic shoes. Bring a water bottle and towel. If training at Goodlife Clubs, a gym membership is required — I can help you arrange this. For your first session, just bring yourself and a positive attitude!",
  },
  {
    question: "Do you provide nutrition advice?",
    answer: "Yes! While I'm not a dietitian, I provide evidence-based nutrition guidance, meal planning tips, and macro calculations to support your training goals. Nutrition is a key part of any fitness journey and I incorporate it into all my coaching programs.",
  },
  {
    question: "Can you train clients under 18?",
    answer: "Yes! I hold a Working With Children Check (WWCC) and am qualified to train youth clients. Parental consent is required for clients under 18, and a parent or guardian must be present during sessions for clients under 16.",
  },
  {
    question: "What are your cancellation policies?",
    answer: "Please provide 24 hours notice for cancellations or rescheduling. Late cancellations (less than 24 hours notice) may be charged at the full session rate. I understand life happens — just communicate with me as early as possible.",
  },
  {
    question: "Do you offer package deals?",
    answer: "Yes! Contact me to discuss package options and pricing that suits your needs and budget. Packages typically offer better value than single sessions and help with commitment and consistency.",
  },
  {
    question: "Where do you train clients?",
    answer: "My primary location is Goodlife Health Clubs Payneham (7 Portrush Rd, Payneham SA 5070). I also offer online coaching for remote clients anywhere in Australia. Some outdoor and home training options may be available — contact me to discuss.",
  },
];
---

<section class="bg-white py-20 md:py-28">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="text-center mb-12">
      <span class="font-heading font-bold text-xs uppercase tracking-widest text-brand-blue mb-3 block">
        Got Questions?
      </span>
      <h2 class="font-heading font-bold text-3xl md:text-4xl lg:text-5xl uppercase tracking-tight text-brand-black">
        Frequently Asked Questions
      </h2>
      <p class="mt-4 font-body text-lg text-gray-600 max-w-xl mx-auto">
        Everything you need to know before getting started.
      </p>
    </div>

    <!-- FAQ accordion -->
    <div class="space-y-3">
      {faqs.map((faq, index) => (
        <details class="group bg-white border border-gray-200 rounded-xl overflow-hidden hover:border-brand-blue transition-colors duration-200">
          <summary class="flex items-center justify-between gap-4 px-6 py-5 cursor-pointer list-none select-none">
            <span class="font-heading font-bold text-base md:text-lg text-brand-blue leading-snug">
              {faq.question}
            </span>
            <!-- Arrow indicator -->
            <span class="flex-shrink-0 w-6 h-6 text-brand-yellow transition-transform duration-300 group-open:rotate-180" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </span>
          </summary>
          <div class="px-6 pb-5">
            <p class="font-body text-gray-600 leading-relaxed">
              {faq.answer}
            </p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
