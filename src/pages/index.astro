---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/home/Hero.astro';
import AboutSection from '../components/home/AboutSection.astro';
import ServicesPreview from '../components/home/ServicesPreview.astro';
import SpecialtiesSection from '../components/home/SpecialtiesSection.astro';
import StatsCounter from '../components/home/StatsCounter.astro';
import TestimonialsSection from '../components/home/TestimonialsSection.astro';
import BlogPreview from '../components/home/BlogPreview.astro';
import BookingSection from '../components/home/BookingSection.astro';
import LocationSection from '../components/home/LocationSection.astro';
import CTASection from '../components/shared/CTASection.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const recentPosts = allPosts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "name": "Petrov Fitness",
      "description": "Professional personal training in Adelaide, South Australia. Specializing in hypertrophy training, body recomposition, and boxing fitness.",
      "url": "https://petrovfitness.com.au",
      "telephone": "+61415522832",
      "email": "petrovcoachfitness@gmail.com",
      "priceRange": "$$",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "7 Portrush Rd",
        "addressLocality": "Payneham",
        "addressRegion": "SA",
        "postalCode": "5070",
        "addressCountry": "AU"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": -34.9085,
        "longitude": 138.6370
      },
      "openingHoursSpecification": [
        { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"], "opens": "06:00", "closes": "20:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Saturday", "opens": "07:00", "closes": "16:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Sunday", "opens": "08:00", "closes": "14:00" }
      ],
      "sameAs": ["https://www.instagram.com/mikhail_saustralia", "https://www.facebook.com/share/189Sg6fTzj/"]
    },
    {
      "@type": "Person",
      "name": "Mikhail Petrov",
      "jobTitle": "Personal Trainer & Boxing Coach",
      "description": "Certified personal trainer with 5+ years experience specializing in hypertrophy training, body recomposition, and boxing fitness in Adelaide, South Australia.",
      "url": "https://petrovfitness.com.au",
      "sameAs": ["https://www.instagram.com/mikhail_saustralia", "https://www.facebook.com/share/189Sg6fTzj/"],
      "alumniOf": { "@type": "EducationalOrganization", "name": "Australian Institute of Fitness" },
      "award": "2019 Silver State Championship Medal - Boxing"
    }
  ]
};
---

<Layout
  title="Mikhail Petrov | Personal Trainer Adelaide | Petrov Fitness"
  description="Transform your body with Mikhail Petrov, Adelaide's expert personal trainer. Specializing in hypertrophy training, fat loss, and boxing fitness. 5+ years experience. Book your first session now!"
  schema={schema}
>
  <Hero />
  <AboutSection />
  <ServicesPreview />
  <SpecialtiesSection />
  <StatsCounter />
  <TestimonialsSection />
  <BlogPreview posts={recentPosts} />
  <CTASection
    title="Ready to Transform Your Fitness?"
    subtitle="Book your first PT session today and take the first step towards your goals"
    badge="50% OFF Your First Session"
    bgColor="yellow"
    secondaryText="Not sure where to start? Schedule a free consultation to discuss your goals"
  />
  <BookingSection />
  <LocationSection />
</Layout>
