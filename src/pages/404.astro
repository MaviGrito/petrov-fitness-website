---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="404 — Page Not Found | Petrov Fitness"
  description="The page you're looking for doesn't exist or has been moved."
>
  <section class="min-h-screen bg-brand-black flex items-center justify-center px-4">
    <div class="text-center">
      <p class="text-8xl md:text-[10rem] font-heading font-black text-brand-yellow leading-none">
        404
      </p>
      <h1 class="text-3xl md:text-4xl font-heading font-bold text-brand-white mt-4 mb-4">
        Page Not Found
      </h1>
      <p class="text-gray-400 text-lg mb-10 max-w-md mx-auto">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/"
          class="inline-block bg-brand-yellow text-brand-black font-heading font-bold px-8 py-3 rounded hover:bg-yellow-400 transition-colors duration-200"
        >
          Go Back Home
        </a>
        <a
          href="/services"
          class="inline-block border-2 border-brand-white text-brand-white font-heading font-bold px-8 py-3 rounded hover:bg-brand-white hover:text-brand-black transition-colors duration-200"
        >
          View Services
        </a>
      </div>
    </div>
  </section>
</Layout>
